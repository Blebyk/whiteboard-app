# Скопируй этот файл в .env.local и заполни значения:
#   PowerShell:  cp .env.example .env.local
#   Bash:        cp .env.example .env.local

# Ключ API от Resend (https://resend.com) — нужен для отправки писем верификации
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL приложения (используется в ссылках верификации email и сброса пароля)
# Для локальной разработки оставь как есть
NEXT_PUBLIC_APP_URL=http://localhost:3000

# (Опционально) секрет для одноразового админ-эндпоинта верификации
# ADMIN_SECRET=changeme
